        <rdfs:range rdf:resource="https://github.com/DOWARC/dowarcLITE#WarcRecord"/>
        <rdfs:comment>The WARC-Record-ID of a single record for which the present record holds additional content.</rdfs:comment>
    </owl:ObjectProperty>
    


